{
  "schemaVersion": 1,
  "name": "Harry Potter",
  "author": "rahul",
  "version": "1.0.0",
  "description": "Chibi Harry Potter desk pet — Gryffindor scarf, golden snitch, Hedwig deliveries and Nimbus sweeping. 18 CSS-animated SVG states.",

  "viewBox": { "x": 0, "y": 0, "width": 200, "height": 200 },

  "layout": {
    "contentBox": { "x": 30, "y": 20, "width": 140, "height": 150 },
    "centerX": 100,
    "baselineY": 172,
    "visibleHeightRatio": 0.5,
    "baselineBottomRatio": 0.05
  },

  "eyeTracking": {
    "enabled": true,
    "states": ["idle"],
    "eyeRatioX": 0.5,
    "eyeRatioY": 0.45,
    "maxOffset": 3,
    "trackingLayers": {
      "eyes": {
        "ids": ["pupil-left", "pupil-right"],
        "maxOffset": 3,
        "ease": 0.2
      }
    }
  },

  "sleepSequence": { "mode": "full" },

  "states": {
    "idle":         ["hp-idle.svg"],
    "yawning":      ["hp-yawning.svg"],
    "dozing":       ["hp-dozing.svg"],
    "collapsing":   ["hp-collapsing.svg"],
    "sleeping":     ["hp-sleeping.svg"],
    "waking":       ["hp-waking.svg"],
    "thinking":     ["hp-thinking.svg"],
    "working":      ["hp-working.svg"],
    "juggling":     ["hp-juggling.svg"],
    "sweeping":     ["hp-sweeping.svg"],
    "carrying":     ["hp-carrying.svg"],
    "error":        ["hp-error.svg"],
    "attention":    ["hp-attention.svg"],
    "notification": ["hp-notification.svg"]
  },

  "workingTiers": [
    { "minSessions": 3, "file": "hp-building.svg" },
    { "minSessions": 2, "file": "hp-juggling.svg" },
    { "minSessions": 1, "file": "hp-working.svg" }
  ],

  "reactions": {
    "drag":       { "file": "hp-react-drag.svg" },
    "clickLeft":  { "file": "hp-react-spark.svg", "duration": 2500 },
    "double":     { "files": ["hp-react-spark.svg"], "duration": 3000 },
    "annoyed":    { "file": "hp-react-annoyed.svg", "duration": 3500 }
  },

  "hitBoxes": {
    "default":  { "x": 62, "y": 42, "w": 76, "h": 130 },
    "sleeping": { "x": 28, "y": 96, "w": 136, "h": 70 }
  },
  "sleepingHitboxFiles": ["hp-sleeping.svg"],

  "miniMode": { "supported": false },

  "timings": {
    "minDisplay": { "attention": 3000 },
    "autoReturn": { "attention": 4000 },
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  }
}
